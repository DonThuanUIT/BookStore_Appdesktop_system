<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>

<HBox fx:id="rootLayout" prefHeight="800.0" prefWidth="1200.0"
      style="-fx-background-color: transparent;"
      stylesheets="@../css/colors.css,@../css/theme.css"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.bookstore.frontend.controller.HomeController">

    <ScrollPane fitToWidth="true" HBox.hgrow="ALWAYS" style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">
        <content>
            <VBox spacing="40.0">
                <padding>
                    <Insets top="40.0" right="40.0" bottom="50.0" left="40.0"/>
                </padding>

                <VBox alignment="CENTER" spacing="20.0">
                    <VBox alignment="CENTER" spacing="5.0">
                        <Label fx:id="lblWelcome" text="Welcome to Neth Bookpoint" styleClass="login-title" style="-fx-font-size: 36px;"/>
                        <Label text="Discover premium editions, rare collections, and your next favorite story in our curated digital bookstore."
                               styleClass="login-subtitle" wrapText="true" textAlignment="CENTER" maxWidth="600"/>
                    </VBox>

                    <HBox alignment="CENTER_LEFT" maxWidth="550.0" style="-fx-background-color: rgba(255, 255, 255, 0.08); -fx-background-radius: 30; -fx-padding: 4;">
                        <TextField fx:id="txtSearch" promptText="Search by title, author, or ISBN..."
                                   style="-fx-background-color: transparent; -fx-text-fill: white; -fx-prompt-text-fill: #AAAAAA; -fx-padding: 10 20; -fx-font-size: 14px;"
                                   HBox.hgrow="ALWAYS"/>
                        <Button text="Search" styleClass="btn-primary" style="-fx-background-radius: 25; -fx-padding: 10 30;"/>
                    </HBox>
                </VBox>

                <VBox spacing="20.0">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="New Arrivals" styleClass="login-title" style="-fx-font-size: 24px;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Hyperlink onAction="#handleViewAll" text="View All →" styleClass="text-link" style="-fx-font-size: 14px;"/>
                    </HBox>

                    <FlowPane fx:id="booksContainer" hgap="25.0" vgap="30.0" alignment="CENTER" />
                </VBox>
            </VBox>
        </content>
    </ScrollPane>

    <fx:include fx:id="bookDetailSidePanel" source="components/BookDetailSidePanelView.fxml" />

</HBox>