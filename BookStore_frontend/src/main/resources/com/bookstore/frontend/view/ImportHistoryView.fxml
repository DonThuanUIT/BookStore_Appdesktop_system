<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bookstore.frontend.controller.ImportHistoryController">

    <VBox spacing="20.0" style="-fx-background-color: #1A1A1A; -fx-padding: 30;">
        <BorderPane>
            <left>
                <VBox spacing="5.0">
                    <Label text="Lịch sử Nhập Hàng" textFill="#FFC107">
                        <font>
                            <Font name="System Bold" size="28.0" />
                        </font>
                    </Label>
                    <Label text="Quản lý và tra cứu các phiếu nhập kho" textFill="#AAAAAA">
                        <font>
                            <Font size="14.0" />
                        </font>
                    </Label>
                </VBox>
            </left>
            <right>
                <Button fx:id="btnCreateImport" onAction="#handleCreateImport" style="-fx-background-color: #FFC107; -fx-text-fill: #1A1A1A; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 10 20;" text="+ Tạo phiếu nhập mới" BorderPane.alignment="CENTER">
                    <font>
                        <Font size="14.0" />
                    </font>
                    <cursor>
                        <javafx.scene.Cursor fx:constant="HAND" />
                    </cursor>
                </Button>
            </right>
        </BorderPane>

        <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #252525; -fx-padding: 15; -fx-background-radius: 10;">
            <TextField fx:id="txtSearch" prefWidth="300.0" promptText="🔍 Tìm kiếm mã phiếu hoặc nhân viên..." style="-fx-background-color: #1A1A1A; -fx-text-fill: white; -fx-prompt-text-fill: #777777; -fx-border-color: #333333; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8;" />
            <Region HBox.hgrow="ALWAYS" />
            <DatePicker fx:id="dpFrom" promptText="Từ ngày" style="-fx-background-color: #1A1A1A; -fx-base: #1A1A1A; -fx-control-inner-background: #1A1A1A;" />
            <DatePicker fx:id="dpTo" promptText="Đến ngày" style="-fx-background-color: #1A1A1A; -fx-base: #1A1A1A; -fx-control-inner-background: #1A1A1A;" />
            <Button onAction="#handleFilter" style="-fx-background-color: transparent; -fx-border-color: #FFC107; -fx-text-fill: #FFC107; -fx-border-radius: 5; -fx-padding: 5 15;" text="Lọc">
                <cursor>
                    <javafx.scene.Cursor fx:constant="HAND" />
                </cursor>
            </Button>
        </HBox>

        <TableView fx:id="tvImports" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-base: #1A1A1A; -fx-control-inner-background: #252525; -fx-table-cell-border-color: #333333; -fx-text-fill: white;">
            <columns>
                <TableColumn fx:id="colId" prefWidth="120.0" text="MÃ PHIẾU" />
                <TableColumn fx:id="colStaff" prefWidth="200.0" text="NHÂN VIÊN PHỤ TRÁCH" />
                <TableColumn fx:id="colDate" prefWidth="180.0" text="NGÀY NHẬP" />
                <TableColumn fx:id="colTotal" prefWidth="150.0" text="TỔNG TIỀN" />
                <TableColumn fx:id="colActions" prefWidth="120.0" text="HÀNH ĐỘNG" style="-fx-alignment: CENTER;" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

        <BorderPane>
            <left>
                <Label fx:id="lblPaginationInfo" text="Showing 0 entries" textFill="#AAAAAA" BorderPane.alignment="CENTER" />
            </left>
            <right>
                <HBox spacing="10.0" alignment="CENTER_RIGHT" BorderPane.alignment="CENTER">
                    <Label text="&lt; Prev" textFill="#AAAAAA" style="-fx-cursor: hand;" />
                    <Label text="1" style="-fx-background-color: #FFC107; -fx-text-fill: #1A1A1A; -fx-padding: 5 10; -fx-background-radius: 3; -fx-font-weight: bold;" />
                    <Label text="Next &gt;" textFill="#AAAAAA" style="-fx-cursor: hand;" />
                </HBox>
            </right>
        </BorderPane>
    </VBox>

    <fx:include fx:id="importDetailSidePanel" source="components/ImportDetailSidePanelView.fxml" StackPane.alignment="CENTER_RIGHT" />

</StackPane>