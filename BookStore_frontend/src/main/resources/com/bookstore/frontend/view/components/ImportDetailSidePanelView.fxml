<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox fx:id="sidePanelRoot" prefWidth="450.0" maxWidth="450.0" style="-fx-background-color: #1E1E1E; -fx-border-color: #333333; -fx-border-width: 0 0 0 1;" stylesheets="@../../css/theme.css" translateX="450.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bookstore.frontend.controller.ImportDetailSidePanelController">

    <HBox alignment="CENTER_LEFT" style="-fx-padding: 20; -fx-border-color: #333333; -fx-border-width: 0 0 1 0;">
        <Label text="Chi tiết phiếu nhập" textFill="WHITE">
            <font><Font name="System Bold" size="20.0" /></font>
        </Label>
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#handleClose" style="-fx-background-color: transparent; -fx-text-fill: #AAAAAA; -fx-font-size: 18px; -fx-cursor: hand;" text="✕" />
    </HBox>

    <VBox spacing="10.0" style="-fx-padding: 20;">
        <HBox spacing="10.0">
            <Label text="🏷 Mã phiếu:" textFill="#AAAAAA" />
            <Label fx:id="lblImportId" text="#IMP-..." textFill="#FFC107">
                <font><Font name="System Bold" size="13.0" /></font>
            </Label>
        </HBox>
        <HBox spacing="10.0">
            <Label text="👤 Nhân viên:" textFill="#AAAAAA" />
            <Label fx:id="lblStaff" text="..." textFill="WHITE" />
        </HBox>
        <HBox spacing="10.0">
            <Label text="📅 Ngày nhập:" textFill="#AAAAAA" />
            <Label fx:id="lblDate" text="..." textFill="WHITE" />
        </HBox>
    </VBox>

    <VBox VBox.vgrow="ALWAYS" spacing="10.0" style="-fx-padding: 0 20 20 20;">
        <Label text="📦 DANH SÁCH SẢN PHẨM" textFill="#FFC107">
            <font><Font name="System Bold" size="14.0" /></font>
        </Label>

        <TableView fx:id="tvDetails" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-base: #1E1E1E; -fx-control-inner-background: #252525; -fx-table-cell-border-color: #333333;">
            <columns>
                <TableColumn fx:id="colTitle" prefWidth="180.0" text="TÊN SÁCH" />
                <TableColumn fx:id="colQty" prefWidth="60.0" style="-fx-alignment: CENTER;" text="SL" />
                <TableColumn fx:id="colPrice" prefWidth="80.0" style="-fx-alignment: CENTER_RIGHT;" text="GIÁ" />
                <TableColumn fx:id="colTotal" prefWidth="90.0" style="-fx-alignment: CENTER_RIGHT;" text="TỔNG" />
            </columns>
        </TableView>
    </VBox>

    <VBox alignment="CENTER_RIGHT" style="-fx-background-color: #252525; -fx-padding: 20;">
        <Label text="TỔNG TIỀN PHIẾU NHẬP" textFill="#AAAAAA">
            <font><Font size="12.0" /></font>
        </Label>
        <Label fx:id="lblTotalCost" text="\$0.00" textFill="#FFC107">
            <font><Font name="System Bold" size="28.0" /></font>
        </Label>
    </VBox>
</VBox>