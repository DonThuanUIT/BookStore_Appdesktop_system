<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="800.0" prefWidth="1200.0" spacing="25.0"
      style="-fx-background-color: transparent;"
      stylesheets="@../css/colors.css,@../css/theme.css"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.bookstore.frontend.controller.InventoryController">

    <padding>
        <Insets top="40.0" right="40.0" bottom="40.0" left="40.0"/>
    </padding>

    <HBox alignment="CENTER_LEFT">
        <VBox spacing="5.0">
            <Label text="Quản lý Kho hàng" styleClass="login-title" style="-fx-font-size: 32px; -fx-text-fill: -fx-accent-gold;"/>
            <Label text="Quản lý danh mục, số lượng tồn kho và giá bán." styleClass="login-subtitle" style="-fx-text-fill: #CCCCCC;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnFilterLowStock" text="≡ Lọc sắp hết hàng" onAction="#handleFilterLowStock"
                styleClass="btn-outline-small" style="-fx-border-color: -fx-accent-gold; -fx-text-fill: -fx-accent-gold; -fx-padding: 10 20; -fx-font-size: 14px; -fx-border-radius: 8;"/>
    </HBox>

    <HBox spacing="40.0" styleClass="sidebar-panel" style="-fx-padding: 20 40; -fx-background-radius: 12; -fx-border-color: rgba(255,255,255,0.1);">
        <VBox spacing="5.0">
            <Label text="TRẠNG THÁI KHO HIỆN TẠI" style="-fx-text-fill: #AAAAAA; -fx-font-size: 12px; -fx-font-weight: bold; -fx-letter-spacing: 1px;"/>
            <HBox spacing="40.0" alignment="BOTTOM_LEFT">
                <VBox spacing="-5.0">
                    <Label fx:id="lblTotalTitles" text="0" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: -fx-accent-gold;"/>
                    <Label text="TỔNG ĐẦU SÁCH" style="-fx-text-fill: #AAAAAA; -fx-font-size: 11px;"/>
                </VBox>
                <Separator orientation="VERTICAL" style="-fx-background-color: rgba(255,255,255,0.2);"/>
                <VBox spacing="-5.0">
                    <Label fx:id="lblLowStock" text="0" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #ff5555;"/>
                    <Label text="SẮP HẾT HÀNG" style="-fx-text-fill: #AAAAAA; -fx-font-size: 11px;"/>
                </VBox>
            </HBox>
        </VBox>
    </HBox>

    <VBox VBox.vgrow="ALWAYS" styleClass="sidebar-panel" style="-fx-background-radius: 12; -fx-border-color: rgba(255,255,255,0.1); -fx-padding: 10;">
        <TableView fx:id="tvInventory" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-base: transparent; -fx-control-inner-background: transparent; -fx-table-cell-border-color: transparent; -fx-table-header-border-color: transparent; -fx-padding: 5;">
            <columns>
                <TableColumn fx:id="colId" text="MÃ" prefWidth="100.0" style="-fx-text-fill: #AAAAAA;"/>
                <TableColumn fx:id="colTitle" text="TÊN SÁCH" prefWidth="350.0" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                <TableColumn fx:id="colAuthor" text="TÁC GIẢ" prefWidth="250.0" style="-fx-text-fill: #AAAAAA;"/>
                <TableColumn fx:id="colQty" text="TỒN KHO" prefWidth="150.0"/>
                <TableColumn fx:id="colPrice" text="GIÁ BÁN" prefWidth="120.0" style="-fx-text-fill: -fx-accent-gold; -fx-font-weight: bold;"/>
                <TableColumn fx:id="colActions" text="THAO TÁC" prefWidth="120.0"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>

        <HBox alignment="CENTER_LEFT" style="-fx-padding: 15 20 5 20; -fx-border-color: rgba(255,255,255,0.1) transparent transparent transparent; -fx-border-width: 1 0 0 0;">
            <Label fx:id="lblPaginationInfo" text="Hiển thị 0 kết quả" style="-fx-text-fill: #AAAAAA; -fx-font-size: 12px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox spacing="8.0">
                <Button text="Trước" styleClass="btn-page"/>
                <Button text="1" styleClass="btn-page, btn-page-active"/>
                <Button text="Tiếp" styleClass="btn-page"/>
            </HBox>
        </HBox>
    </VBox>

</VBox>