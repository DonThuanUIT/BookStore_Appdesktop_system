<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20.0" styleClass="bg-white" stylesheets="@../css/theme.css"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.bookstore.frontend.controller.InventoryController">

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="20.0">
        <children>
            <Label styleClass="text-title-gold" text="Inventory Management" />
            <Region HBox.hgrow="ALWAYS" />
            <Button mnemonicParsing="false" onAction="#onAddNewBook" styleClass="btn-login" text="+ Add New Book" />
        </children>
    </HBox>

    <TableView fx:id="bookTable" VBox.vgrow="ALWAYS" styleClass="book-card">
        <columns>
            <TableColumn fx:id="colTitle" prefWidth="250.0" text="Book Title" />
            <TableColumn fx:id="colAuthor" prefWidth="150.0" text="Author" />
            <TableColumn fx:id="colPublisher" prefWidth="150.0" text="Publisher" />
            <TableColumn fx:id="colPrice" prefWidth="100.0" text="Price" />
            <TableColumn fx:id="colQuantity" prefWidth="80.0" text="Qty" />
            <TableColumn fx:id="colDescription" prefWidth="300.0" text="Description" />
            <TableColumn fx:id="colAction" prefWidth="100.0" text="Action" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>
</VBox>