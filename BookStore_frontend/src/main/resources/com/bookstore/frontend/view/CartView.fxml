<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.image.ImageView?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.bookstore.frontend.controller.CartController"
           stylesheets="@../css/colors.css,@../css/theme.css"
           style="-fx-background-color: #1A1A1A;">

    <HBox spacing="0">

        <!-- ====== LEFT SIDEBAR ====== -->
        <VBox prefWidth="280.0" minWidth="280.0" maxWidth="280.0"
              style="-fx-background-color: #141414; -fx-border-color: #2A2A2A; -fx-border-width: 0 1 0 0;">

            <!-- Header sidebar -->
            <VBox style="-fx-padding: 30 20 20 20; -fx-border-color: #2A2A2A; -fx-border-width: 0 0 1 0;" spacing="6.0">
                <Label text="📚" style="-fx-font-size: 36px;" />
                <Label text="Neth Bookpoint" textFill="#FFC107">
                    <font><Font name="System Bold" size="18.0" /></font>
                </Label>
                <Label text="Giỏ sách của bạn" textFill="#777777">
                    <font><Font size="12.0" /></font>
                </Label>
            </VBox>

            <!-- Random book cover -->
            <VBox alignment="CENTER" VBox.vgrow="ALWAYS" spacing="15.0" style="-fx-padding: 20;">
                <Label text="📖 Gợi ý hôm nay" textFill="#555555">
                    <font><Font size="11.0" /></font>
                </Label>
                <ImageView fx:id="imgRandomBook"
                           fitWidth="180.0"
                           fitHeight="260.0"
                           preserveRatio="true"
                           smooth="true"
                           cache="true"
                           style="-fx-effect: dropshadow(gaussian, rgba(0,0,0,0.7), 15, 0, 0, 4);" />
            </VBox>

            <!-- Summary box -->
            <VBox spacing="12.0" style="-fx-padding: 20; -fx-background-color: #1E1E1E; -fx-border-color: #2A2A2A; -fx-border-width: 1 0 0 0;">
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <Label text="Tổng cộng" textFill="#AAAAAA">
                        <font><Font size="13.0" /></font>
                    </Label>
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="lblTotalPrice" text="0 đ" textFill="#FFC107">
                        <font><Font name="System Bold" size="18.0" /></font>
                    </Label>
                </HBox>
                <Button fx:id="btnCheckout" onAction="#handleCheckout"
                        prefWidth="240.0" prefHeight="44.0"
                        text="🛍 Đặt hàng ngay"
                        style="-fx-background-color: #FFC107; -fx-text-fill: #1A1A1A; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-size: 14px;">
                    <cursor>
                        <javafx.scene.Cursor fx:constant="HAND" />
                    </cursor>
                </Button>
            </VBox>
        </VBox>

        <!-- ====== MAIN CART CONTENT ====== -->
        <VBox HBox.hgrow="ALWAYS" spacing="0">

            <!-- Top header bar -->
            <HBox alignment="CENTER_LEFT" spacing="16.0"
                  style="-fx-padding: 24 30 20 30; -fx-border-color: #2A2A2A; -fx-border-width: 0 0 1 0; -fx-background-color: #1A1A1A;">
                <Label text="🛒 Giỏ hàng của tôi" textFill="WHITE">
                    <font><Font name="System Bold" size="22.0" /></font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblItemCount" text="0 sản phẩm" textFill="#777777">
                    <font><Font size="13.0" /></font>
                </Label>
            </HBox>

            <!-- Column headers -->
            <HBox style="-fx-padding: 12 30; -fx-background-color: #1E1E1E; -fx-border-color: #2A2A2A; -fx-border-width: 0 0 1 0;"
                  alignment="CENTER_LEFT" spacing="0">
                <Label text="SÁCH" textFill="#555555" prefWidth="380.0">
                    <font><Font name="System Bold" size="11.0" /></font>
                </Label>
                <Label text="SỐ LƯỢNG" textFill="#555555" prefWidth="120.0" style="-fx-alignment: center;" />
                <Region HBox.hgrow="ALWAYS" />
                <Label text="THÀNH TIỀN" textFill="#555555" prefWidth="130.0" style="-fx-alignment: center-right;" />
                <Label text="" prefWidth="80.0" />
            </HBox>

            <!-- Cart Items scroll -->
            <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true"
                        style="-fx-background: #1A1A1A; -fx-background-color: transparent; -fx-border-width: 0;">
                <content>
                    <VBox fx:id="cartItemsContainer" spacing="0"
                          style="-fx-background-color: #1A1A1A;" />
                </content>
            </ScrollPane>
        </VBox>
    </HBox>
</StackPane>