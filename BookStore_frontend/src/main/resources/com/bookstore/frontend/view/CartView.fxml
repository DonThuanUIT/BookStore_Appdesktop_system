<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.StackPane?>

<!-- Thay VBox cha thành StackPane để ảnh nền hiển thị toàn màn hình -->
<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.bookstore.frontend.controller.CartController"
           style="-fx-background-image: url('/image/libraryBackground.jpg'); -fx-background-size: cover; -fx-background-position: center;">

    <!-- Lớp phủ mờ nhẹ để chữ dễ đọc hơn trên nền ảnh kệ sách -->
    <VBox style="-fx-background-color: rgba(0,0,0,0.4);" />

    <VBox prefHeight="730.0" prefWidth="1000.0" spacing="10.0" style="-fx-padding: 20;">
        <children>
            <!-- Header -->
            <HBox alignment="CENTER_LEFT" prefWidth="960.0" spacing="40.0" style="-fx-padding: 10;">
                <children>
                    <Label text="Neth Bookpoint" style="-fx-text-fill: white; -fx-font-weight: bold;" styleClass="header-title">
                        <font> <Font size="24.0" /> </font>
                    </Label>
                </children>
            </HBox>

            <!-- Nội dung chính trong suốt -->
            <HBox prefHeight="650.0" prefWidth="1000.0" spacing="20" VBox.vgrow="ALWAYS">
                <children>
                    <!-- Sidebar trong suốt -->
                    <VBox prefWidth="300.0" alignment="CENTER"
                          style="-fx-background-color: rgba(255, 255, 255, 0.1); -fx-background-radius: 18; -fx-border-color: rgba(255,255,255,0.2); -fx-border-radius: 18;">
                        <padding> <Insets bottom="20" left="20" right="20" top="20" /> </padding>
                        <children>
                            <ImageView fx:id="imgRandomBook"
                                       fitWidth="240.0"
                                       fitHeight="340.0"
                                       preserveRatio="true"
                                       smooth="true"
                                       cache="true">
                            </ImageView>
                        </children>
                    </VBox>

                    <!-- Cart Details trong suốt -->
                    <VBox alignment="TOP_CENTER" spacing="24.0" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: rgba(255, 255, 255, 0.85); -fx-background-radius: 18; -fx-padding: 30;">
                        <children>
                            <Label text="Your Cart Details" style="-fx-text-fill: #333;">
                                <font> <Font name="System Bold" size="28.0" /> </font>
                            </Label>

                            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
                                <content>
                                    <VBox fx:id="cartItemsContainer" spacing="18.0" alignment="TOP_CENTER" style="-fx-background-color: transparent;" />
                                </content>
                            </ScrollPane>

                            <VBox alignment="CENTER" spacing="16.0" style="-fx-background-color: rgba(0,0,0,0.05); -fx-background-radius: 14; -fx-padding: 20;">
                                <children>
                                    <HBox alignment="CENTER" spacing="10.0">
                                        <children>
                                            <Label text="Total Price:" style="-fx-font-size: 22px; -fx-font-weight: bold;" />
                                            <Label fx:id="lblTotalPrice" text="0đ" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #d35400;" />
                                        </children>
                                    </HBox>
                                    <Button fx:id="btnCheckout" onAction="#handleCheckout" prefHeight="50.0" prefWidth="260.0" styleClass="btn-primary" text="Proceed to Checkout" />
                                </children>
                            </VBox>
                        </children>
                    </VBox>
                </children>
            </HBox>
        </children>
    </VBox>
</StackPane>