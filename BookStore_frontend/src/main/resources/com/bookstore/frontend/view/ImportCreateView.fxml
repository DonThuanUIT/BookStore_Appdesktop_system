<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<HBox spacing="30.0" style="-fx-background-color: #1A1A1A; -fx-padding: 30;"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bookstore.frontend.controller.ImportCreateController">

    <VBox prefWidth="380.0" maxWidth="380.0" spacing="25.0" HBox.hgrow="NEVER">

        <VBox spacing="20.0" style="-fx-background-color: #252525; -fx-padding: 25; -fx-background-radius: 10;">
            <Label text="📋 Chi tiết nhập hàng" textFill="WHITE">
                <font><Font name="System Bold" size="22.0" /></font>
            </Label>

            <VBox spacing="8.0">
                <Label text="CHỌN SÁCH ĐÃ CÓ (nếu là sách cũ hãy chọn gợi ý, nếu bạn nhập sách mới hãy nhấn vào nút thêm mới nhé !)"
                       textFill="#AAAAAA"
                       wrapText="true"
                       style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-line-spacing: 4px;"/>

                <ComboBox fx:id="cbBooks" editable="true" maxWidth="Infinity" promptText="Tìm kiếm tên sách..." style="-fx-background-color: #1A1A1A; -fx-control-inner-background: #1A1A1A; -fx-text-base-color: white; -fx-border-color: #333333; -fx-border-radius: 5; -fx-padding: 5; -fx-font-size: 14px;"/>
                <Button fx:id="btnAddNewBook" onAction="#handleAddNewBook" style="-fx-background-color: transparent; -fx-text-fill: #FFC107; -fx-cursor: hand; -fx-padding: 5 0 0 0; -fx-font-weight: bold;" text="+ Thêm sách mới" />
            </VBox>

            <HBox spacing="15.0">
                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                    <Label text="SỐ LƯỢNG" textFill="#AAAAAA" style="-fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <TextField fx:id="txtQuantity" text="1" alignment="CENTER" style="-fx-background-color: #1A1A1A; -fx-text-fill: white; -fx-border-color: #333333; -fx-border-radius: 5; -fx-padding: 10;"/>
                </VBox>
                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                    <Label text="GIÁ NHẬP (VNĐ)" textFill="#AAAAAA" style="-fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <TextField fx:id="txtImportPrice" text="0" alignment="CENTER" style="-fx-background-color: #1A1A1A; -fx-text-fill: white; -fx-border-color: #333333; -fx-border-radius: 5; -fx-padding: 10;"/>
                </VBox>
            </HBox>

            <Button onAction="#handleAddToList" maxWidth="Infinity" style="-fx-background-color: #FFC107; -fx-text-fill: #1A1A1A; -fx-font-weight: bold; -fx-padding: 12; -fx-background-radius: 20; -fx-font-size: 14px;" text="+ Thêm vào danh sách">
                <cursor><javafx.scene.Cursor fx:constant="HAND" /></cursor>
                <VBox.margin><Insets top="10.0" /></VBox.margin>
            </Button>
        </VBox>

        <HBox spacing="15.0" style="-fx-background-color: #162429; -fx-border-color: #00BCD4; -fx-border-width: 0 0 0 4; -fx-padding: 15; -fx-background-radius: 0 5 5 0;">
            <Label text="ⓘ" textFill="#00BCD4">
                <font><Font name="System Bold" size="20.0" /></font>
            </Label>
            <Label text="Lưu ý: Hệ thống sẽ tự động cập nhật số lượng tồn kho sau khi hoàn tất phiếu nhập." textFill="#88B0B9" wrapText="true" style="-fx-font-size: 13px; -fx-line-spacing: 3px;" />
        </HBox>

    </VBox>

    <VBox spacing="20.0" HBox.hgrow="ALWAYS" style="-fx-background-color: #252525; -fx-padding: 30; -fx-background-radius: 10;">
        <BorderPane>
            <left>
                <Label text="📑 Danh sách chờ nhập" textFill="WHITE" BorderPane.alignment="CENTER">
                    <font><Font name="System Bold" size="22.0" /></font>
                </Label>
            </left>
        </BorderPane>

        <TableView fx:id="tvCart" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-base: #1A1A1A; -fx-control-inner-background: #1E1E1E; -fx-table-cell-border-color: #333333; -fx-text-fill: white;">
            <columns>
                <TableColumn fx:id="colTitle" prefWidth="250.0" text="TÊN SÁCH" />
                <TableColumn fx:id="colQty" prefWidth="90.0" style="-fx-alignment: CENTER;" text="SỐ LƯỢNG" />
                <TableColumn fx:id="colPrice" prefWidth="120.0" style="-fx-alignment: CENTER_RIGHT;" text="GIÁ NHẬP" />
                <TableColumn fx:id="colTotal" prefWidth="120.0" style="-fx-alignment: CENTER_RIGHT;" text="THÀNH TIỀN" />
                <TableColumn fx:id="colAction" prefWidth="90.0" style="-fx-alignment: CENTER;" text="HÀNH ĐỘNG" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

        <HBox alignment="CENTER_RIGHT" spacing="40.0" style="-fx-padding: 20 0 0 0; -fx-border-color: #333333; -fx-border-width: 1 0 0 0;">
            <VBox alignment="CENTER_RIGHT" spacing="5.0">
                <Label text="TỔNG CHI PHÍ DỰ KIẾN" textFill="#AAAAAA" style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
                <Label fx:id="lblTotalCartCost" text="0 đ" textFill="#FFC107">
                    <font><Font name="System Bold" size="36.0" /></font>
                </Label>
            </VBox>

            <Button fx:id="btnSubmit" onAction="#handleSubmitImport" style="-fx-background-color: #FFC107; -fx-text-fill: #1A1A1A; -fx-font-weight: bold; -fx-padding: 15 40; -fx-background-radius: 30; -fx-font-size: 16px;" text="Hoàn tất phiếu nhập">
                <cursor><javafx.scene.Cursor fx:constant="HAND" /></cursor>
            </Button>
        </HBox>
    </VBox>

</HBox>