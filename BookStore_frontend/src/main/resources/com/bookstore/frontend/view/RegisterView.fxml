<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<StackPane fx:id="rootStackPane" prefHeight="700.0" prefWidth="1100.0"
           stylesheets="@../css/colors.css, @../css/theme.css"
           xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.bookstore.frontend.controller.RegisterController">
    <children>
        <ImageView fx:id="backgroundImage" pickOnBounds="true" preserveRatio="false">
            <image>
                <Image url="@../image/libraryBackground.jpg" />
            </image>
        </ImageView>

        <Pane styleClass="overlay" />

        <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity"
              prefHeight="500.0" prefWidth="450.0" spacing="10.0" styleClass="login-box">

            <children>
                <VBox fx:id="registerForm" alignment="CENTER" spacing="15.0">
                    <children>

                        <VBox alignment="CENTER" spacing="2.0">
                            <Label styleClass="login-title" text="Tạo tài khoản" style="-fx-font-size: 36px;" />
                            <Label styleClass="login-subtitle" text="Đăng ký và trở thành thành viên của tiệm sách chúng tôi nhé." />
                        </VBox>

                        <TextField fx:id="txtUsername" promptText="Tên đăng nhập" styleClass="custom-text-field" />
                        <TextField fx:id="txtEmail" promptText="Địa chỉ email" styleClass="custom-text-field" />

                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <StackPane alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                                <Button fx:id="btnRequestOtp" onAction="#handleRequestOtp" text="Nhận OTP" styleClass="btn-outline-small" />
                                <Label fx:id="lblCountdown" text="03:00" styleClass="text-error" style="-fx-font-weight: bold; -fx-font-size: 14px;" visible="false" managed="false" />
                            </StackPane>
                        </HBox>

                        <HBox fx:id="otpContainer" alignment="CENTER_LEFT" spacing="10.0" visible="false" managed="false">
                            <TextField fx:id="txtOtp" promptText="Nhập mã OTP 6 số" styleClass="custom-text-field" HBox.hgrow="ALWAYS" />
                        </HBox>

                        <StackPane fx:id="passwordContainer" visible="false" managed="false">
                            <PasswordField fx:id="txtPassword" promptText="Mật khẩu" styleClass="custom-text-field" />
                            <TextField fx:id="txtPasswordVisible" managed="false" visible="false"
                                       promptText="Mật khẩu" styleClass="custom-text-field" />
                            <Button fx:id="btnTogglePassword" onAction="#togglePassword" text="📕"
                                    StackPane.alignment="CENTER_RIGHT" styleClass="btn-icon" />
                        </StackPane>

                        <StackPane fx:id="confirmPasswordContainer" visible="false" managed="false">
                            <PasswordField fx:id="txtConfirmPassword" promptText="Xác nhận mật khẩu" styleClass="custom-text-field" />
                            <TextField fx:id="txtConfirmPasswordVisible" managed="false" visible="false"
                                       promptText="Xác nhận mật khẩu" styleClass="custom-text-field" />
                            <Button fx:id="btnToggleConfirm" onAction="#toggleConfirm" text="📕"
                                    StackPane.alignment="CENTER_RIGHT" styleClass="btn-icon" />
                        </StackPane>

                        <StackPane fx:id="registerBtnContainer" visible="false" managed="false">
                            <children>
                                <Button fx:id="btnRegister" onAction="#handleRegister" maxWidth="Infinity"
                                        mnemonicParsing="false" styleClass="login-button" text="Đăng ký tài khoản" />

                                <VBox fx:id="loadingProgress" alignment="CENTER" spacing="5.0" visible="false" managed="false">
                                    <children>
                                        <ProgressIndicator prefHeight="35.0" prefWidth="35.0" />
                                        <Label text="Đang xử lý ... " style="-fx-text-fill: -fx-accent-gold; -fx-font-size: 12px;" />
                                    </children>
                                </VBox>
                            </children>
                            <VBox.margin><Insets top="5.0" /></VBox.margin>
                        </StackPane>

                        <HBox alignment="CENTER" spacing="5.0">
                            <children>
                                <Label styleClass="login-subtitle" text="Bạn đã có tài khoản?" />
                                <Hyperlink onAction="#goToLogin" styleClass="text-link" text="Đăng nhập nào ❤️" />
                            </children>
                        </HBox>

                    </children>
                </VBox>

                <Label fx:id="lblMessage" textAlignment="CENTER" styleClass="text-error" wrapText="true">
                    <VBox.margin><Insets top="5.0" /></VBox.margin>
                </Label>

            </children>
            <padding>
                <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
            </padding>
        </VBox>
    </children>
</StackPane>