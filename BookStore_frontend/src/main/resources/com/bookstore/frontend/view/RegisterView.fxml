<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="650.0" prefWidth="1100.0"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.bookstore.frontend.controller.RegisterController">
    <children>
        <HBox prefHeight="650.0" prefWidth="1100.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <StackPane style="-fx-background-color: black;" HBox.hgrow="ALWAYS">
                    <children>
                        <Pane maxHeight="Infinity" maxWidth="Infinity"
                              style="-fx-background-color: linear-gradient(to bottom right, #0a1630, #12284c 50%, #1e3a5f);"
                              StackPane.alignment="CENTER" />
                        <VBox alignment="CENTER_LEFT" maxWidth="450.0" spacing="25.0" StackPane.alignment="CENTER_LEFT">
                            <StackPane.margin>
                                <Insets left="60.0" right="60.0" />
                            </StackPane.margin>
                            <children>
                                <Label style="-fx-text-fill: #ffd76a; -fx-font-family: serif; -fx-font-size: 46px; -fx-font-weight: bold; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 10, 0, 0, 4);"
                                       text="Neth BookPoint" />
                                <Label style="-fx-text-fill: rgba(255,255,255,0.9); -fx-font-size: 18px; -fx-font-family: serif; -fx-line-spacing: 5px;"
                                       text="Join our dedicated team of professionals. Streamline your workflow and manage the bookstore ecosystem with our secure administration platform."
                                       wrapText="true" />
                                <Region prefHeight="40.0" />
                                <VBox spacing="10.0" style="-fx-border-color: transparent transparent transparent #ffd76a; -fx-border-width: 0 0 0 3; -fx-padding: 0 0 0 15;">
                                    <children>
                                        <Label style="-fx-text-fill: #EEE8AA; -fx-font-family: serif; -fx-font-size: 16px; -fx-font-style: italic;"
                                               text="&quot;Knowledge is the foundation of our success.&quot;" />
                                        <Label style="-fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 13px; -fx-text-transform: uppercase; -fx-letter-spacing: 2px;"
                                               text="Internal Staff Portal" />
                                    </children>
                                </VBox>
                            </children>
                        </VBox>
                    </children>
                </StackPane>

                <StackPane style="-fx-background-color: #050b14;" HBox.hgrow="ALWAYS">
                    <children>
                        <VBox alignment="CENTER" maxWidth="400.0" spacing="25.0"
                              style="-fx-background-color: rgba(15, 28, 50, 0.85); -fx-background-radius: 16; -fx-border-color: rgba(255, 215, 0, 0.15); -fx-border-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 20, 0, 0, 10);"
                              StackPane.alignment="CENTER">
                            <padding>
                                <Insets bottom="45.0" left="45.0" right="45.0" top="45.0" />
                            </padding>
                            <children>
                                <VBox alignment="CENTER" spacing="10.0">
                                    <children>
                                        <Label alignment="CENTER" maxWidth="Infinity" styleClass="text-title-gold"
                                               style="-fx-font-size: 28px;" text="Staff Registration" wrapText="true" />
                                        <Label alignment="CENTER" maxWidth="Infinity" styleClass="text-description"
                                               style="-fx-font-size: 14px; -fx-text-fill: rgba(255,255,255,0.6);"
                                               text="Please provide your credentials to proceed"
                                               wrapText="true" />
                                    </children>
                                </VBox>

                                <VBox spacing="20.0" maxWidth="Infinity">
                                    <children>
                                        <StackPane alignment="CENTER_RIGHT">
                                            <children>
                                                <TextField fx:id="username" promptText="Username"
                                                           styleClass="custom-input" prefHeight="45.0" />
                                                <Label styleClass="input-icon" text="\@" style="-fx-padding: 0 15 0 0; -fx-text-fill: rgba(255,255,255,0.4);" />
                                            </children>
                                        </StackPane>

                                        <StackPane alignment="CENTER_RIGHT">
                                            <children>
                                                <TextField fx:id="passwordVisible"
                                                           promptText="Password" styleClass="custom-input"
                                                           prefHeight="45.0" visible="false" />
                                                <PasswordField fx:id="password" promptText="Password"
                                                               styleClass="custom-input" prefHeight="45.0" />
                                                <Button fx:id="btnTogglePassword" onAction="#togglePassword"
                                                        styleClass="btn-eye" text="Show" style="-fx-background-color: transparent; -fx-text-fill: #ffd76a; -fx-cursor: hand;">
                                                    <StackPane.margin>
                                                        <Insets right="10.0" />
                                                    </StackPane.margin>
                                                </Button>
                                            </children>
                                        </StackPane>

                                        <StackPane alignment="CENTER_RIGHT">
                                            <children>
                                                <TextField fx:id="confirmPasswordVisible"
                                                           promptText="Confirm Password"
                                                           styleClass="custom-input" prefHeight="45.0" visible="false" />
                                                <PasswordField fx:id="confirmPassword"
                                                               promptText="Confirm Password"
                                                               styleClass="custom-input" prefHeight="45.0" />
                                                <Button fx:id="btnToggleConfirmPassword"
                                                        onAction="#toggleConfirmPassword" styleClass="btn-eye"
                                                        text="Show" style="-fx-background-color: transparent; -fx-text-fill: #ffd76a; -fx-cursor: hand;">
                                                    <StackPane.margin>
                                                        <Insets right="10.0" />
                                                    </StackPane.margin>
                                                </Button>
                                            </children>
                                        </StackPane>

                                        <VBox spacing="8.0">
                                            <children>
                                                <Label style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-family: serif; -fx-font-size: 13px;"
                                                       text="Role Assignment" />
                                                <ComboBox fx:id="role" disable="true" prefHeight="45.0" maxWidth="Infinity"
                                                          style="-fx-background-color: rgba(255,255,255,0.05); -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: white; -fx-font-family: serif; -fx-font-size: 14px;" />
                                            </children>
                                        </VBox>

                                        <Label fx:id="lblMessage"
                                               style="-fx-text-fill: #ff6b6b; -fx-font-size: 13px;"
                                               wrapText="true" minHeight="20.0" />

                                        <Button fx:id="btnRegister" maxWidth="Infinity" prefHeight="48.0"
                                                onAction="#handleRegister" styleClass="btn-login"
                                                style="-fx-font-weight: bold; -fx-letter-spacing: 1px;" text="CREATE ACCOUNT" />

                                        <HBox alignment="CENTER" spacing="8.0" style="-fx-padding: 10 0 0 0;">
                                            <children>
                                                <Label style="-fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 13px;" text="Already registered?" />
                                                <Hyperlink onAction="#navigateToLogin" styleClass="link-create"
                                                           style="-fx-text-fill: #ffd76a; -fx-font-size: 13px; -fx-underline: true; -fx-padding: 0;" text="Sign in here" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>
                    </children>
                </StackPane>
            </children>
        </HBox>
    </children>
</AnchorPane>