<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<StackPane fx:id="rootStackPane" prefHeight="700.0" prefWidth="1100.0"
           stylesheets="@../css/colors.css, @../css/theme.css"
           xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.bookstore.frontend.controller.RegisterController">
    <children>
        <ImageView fx:id="backgroundImage" pickOnBounds="true" preserveRatio="false">
            <image>
                <Image url="@../image/libraryBackground.jpg" />
            </image>
        </ImageView>

        <Pane styleClass="overlay" />

        <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity"
              prefHeight="620.0" prefWidth="450.0" spacing="10.0" styleClass="login-box">

            <children>
                <VBox fx:id="registerForm" alignment="CENTER" spacing="15.0">
                    <children>

                        <VBox alignment="CENTER" spacing="2.0">
                            <Label styleClass="login-title" text="Create Account" style="-fx-font-size: 36px;" />
                            <Label styleClass="login-subtitle" text="Join our literary community." />
                        </VBox>

                        <TextField fx:id="txtUsername" promptText="Full Name / Username" styleClass="custom-text-field" />
                        <TextField fx:id="txtEmail" promptText="Email Address" styleClass="custom-text-field" />
                        <TextField fx:id="txtAddress" promptText="Home Address" styleClass="custom-text-field" />

                        <VBox spacing="3.0">
                            <Label text="Account Role:" styleClass="login-subtitle" style="-fx-font-size: 12px; -fx-opacity: 0.8;" />
                            <ComboBox fx:id="cbRole" maxWidth="Infinity" styleClass="custom-combo-box">
                                <items>
                                    <FXCollections fx:factory="observableArrayList">
                                        <String fx:value="CUSTOMER" />
                                        <String fx:value="STAFF" />
                                        <String fx:value="ADMIN" />
                                    </FXCollections>
                                </items>
                            </ComboBox>
                        </VBox>

                        <StackPane>
                            <PasswordField fx:id="txtPassword" promptText="Password" styleClass="custom-text-field" />
                            <TextField fx:id="txtPasswordVisible" managed="false" visible="false"
                                       promptText="Password" styleClass="custom-text-field" />
                            <Button fx:id="btnTogglePassword" onAction="#togglePassword" text="👁"
                                    StackPane.alignment="CENTER_RIGHT" styleClass="btn-icon" />
                        </StackPane>

                        <StackPane>
                            <PasswordField fx:id="txtConfirmPassword" promptText="Confirm Password" styleClass="custom-text-field" />
                            <TextField fx:id="txtConfirmPasswordVisible" managed="false" visible="false"
                                       promptText="Confirm Password" styleClass="custom-text-field" />
                            <Button fx:id="btnToggleConfirm" onAction="#toggleConfirm" text="👁"
                                    StackPane.alignment="CENTER_RIGHT" styleClass="btn-icon" />
                        </StackPane>

                        <StackPane>
                            <children>
                                <Button fx:id="btnRegister" onAction="#handleRegister" maxWidth="Infinity"
                                        mnemonicParsing="false" styleClass="login-button" text="Sign Up" />

                                <VBox fx:id="loadingProgress" alignment="CENTER" spacing="5.0" visible="false" managed="false">
                                    <children>
                                        <ProgressIndicator prefHeight="35.0" prefWidth="35.0" />
                                        <Label text="Creating account..." style="-fx-text-fill: -fx-accent-gold; -fx-font-size: 12px;" />
                                    </children>
                                </VBox>
                            </children>
                            <VBox.margin><Insets top="5.0" /></VBox.margin>
                        </StackPane>

                        <HBox alignment="CENTER" spacing="5.0">
                            <children>
                                <Label styleClass="login-subtitle" text="Already have an account?" />
                                <Hyperlink onAction="#goToLogin" styleClass="text-link" text="Sign In" />
                            </children>
                        </HBox>

                    </children>
                </VBox>

                <!-- Nhãn báo lỗi -->
                <Label fx:id="lblMessage" textAlignment="CENTER" styleClass="text-error" wrapText="true">
                    <VBox.margin><Insets top="5.0" /></VBox.margin>
                </Label>

            </children>

            <padding>
                <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
            </padding>
        </VBox>
    </children>
</StackPane>