<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="800.0" prefWidth="1100.0" spacing="20.0" styleClass="bg-white" stylesheets="@../css/theme.css"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.bookstore.frontend.controller.ShopController">

    <children>
        <VBox alignment="CENTER" spacing="8.0" style="-fx-padding: 10 0 10 0;">
            <children>
                <Label style="-fx-text-fill: -fx-accent-gold;" text="Explore All Books Here">
                    <font>
                        <Font name="System Bold" size="32.0" />
                    </font>
                </Label>
                <Label style="-fx-text-fill: #666666;"
                       text="Browse your favorite books, discover classics, and explore more beyond the featured collection."
                       textAlignment="CENTER" wrapText="true">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Label>
            </children>
        </VBox>

        <HBox alignment="CENTER" spacing="15.0" style="-fx-padding: 10 0 10 0;">
            <children>
                <ComboBox fx:id="comboSearchType" prefWidth="150.0" promptText="Search By"
                          style="-fx-background-radius: 20; -fx-padding: 5 10 5 10; -fx-background-color: white; -fx-border-color: #d8c27a; -fx-border-radius: 20;" />

                <TextField fx:id="txtSearch" prefWidth="450.0" promptText="Enter keywords..."
                           style="-fx-background-radius: 20; -fx-padding: 10 20 10 20; -fx-border-color: #e5e5e5; -fx-border-radius: 20;" />

                <Button onAction="#onSearch" mnemonicParsing="false" prefWidth="100.0"
                        styleClass="btn-primary" text="Search" />
            </children>
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="15.0"
              style="-fx-background-color: #faf7ef; -fx-background-radius: 12; -fx-padding: 15 25 15 25;">
            <children>
                <Label fx:id="lblBookCount" style="-fx-text-fill: #666666;" text="0 books available">
                    <font>
                        <Font name="System Italic" size="14.0" />
                    </font>
                </Label>

                <Region HBox.hgrow="ALWAYS" />

                <Label style="-fx-text-fill: -fx-primary-black;" text="Sort by:">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Label>
                <Button mnemonicParsing="false" styleClass="btn-sort" text="Popular" />
                <Button mnemonicParsing="false" styleClass="btn-sort" text="Newest" />
                <Button mnemonicParsing="false" styleClass="btn-sort" text="Price" />
            </children>
        </HBox>

        <ScrollPane fx:id="scrollPane" fitToWidth="true" style="-fx-background-color: transparent; -fx-background: white;"
                    VBox.vgrow="ALWAYS">
            <content>
                <FlowPane fx:id="bookContainer" alignment="TOP_CENTER" hgap="30.0" vgap="30.0"
                          style="-fx-padding: 25 15 25 15; -fx-background-color: white;" />
            </content>
        </ScrollPane>

    </children>

    <padding>
        <Insets bottom="25.0" left="30.0" right="30.0" top="25.0" />
    </padding>
</VBox>