<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox prefHeight="800.0" prefWidth="1200.0" spacing="30.0"
      style="-fx-background-color: transparent;"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.bookstore.frontend.controller.ShopController">

    <padding>
        <Insets top="30.0" right="40.0" bottom="30.0" left="40.0"/>
    </padding>

    <VBox minWidth="260.0" prefWidth="260.0" spacing="25.0" styleClass="sidebar-panel">
        <padding>
            <Insets top="25.0" right="20.0" bottom="25.0" left="20.0"/>
        </padding>

        <Label text="Filters" styleClass="login-title" style="-fx-font-size: 24px;"/>
        <Separator style="-fx-background-color: rgba(255,255,255,0.1);"/>

        <VBox spacing="15.0">
            <Label text="Search" styleClass="login-title" style="-fx-font-size: 16px; -fx-text-fill: -fx-accent-gold;"/>
            <TextField fx:id="txtSearch" promptText="Search title or author..." styleClass="custom-text-field" style="-fx-background-color: rgba(255,255,255,0.05);"/>
        </VBox>

        <VBox spacing="15.0">
            <Label text="Price Range" styleClass="login-title" style="-fx-font-size: 16px; -fx-text-fill: -fx-accent-gold;"/>
            <HBox spacing="10.0" alignment="CENTER_LEFT">
                <TextField fx:id="txtMinPrice" promptText="Min $" styleClass="custom-text-field" prefWidth="80.0" style="-fx-background-color: rgba(255,255,255,0.05);"/>
                <Label text="-" style="-fx-text-fill: white;"/>
                <TextField fx:id="txtMaxPrice" promptText="Max $" styleClass="custom-text-field" prefWidth="80.0" style="-fx-background-color: rgba(255,255,255,0.05);"/>
            </HBox>
        </VBox>

        <VBox spacing="15.0">
            <Label text="Categories" styleClass="login-title" style="-fx-font-size: 16px; -fx-text-fill: -fx-accent-gold;"/>
            <VBox fx:id="categoriesContainer" spacing="10.0">
                <CheckBox text="Fantasy" styleClass="custom-checkbox"/>
                <CheckBox text="Mystery &amp; Thriller" styleClass="custom-checkbox" selected="true"/>
                <CheckBox text="Classics" styleClass="custom-checkbox"/>
                <CheckBox text="Science Fiction" styleClass="custom-checkbox"/>
            </VBox>
        </VBox>
    </VBox>

    <VBox HBox.hgrow="ALWAYS" spacing="20.0">
        <HBox alignment="BOTTOM_LEFT">
            <VBox spacing="5.0">
                <Label text="All Books" styleClass="login-title" style="-fx-font-size: 32px;"/>
                <Label fx:id="lblStatus" text="Showing results..." styleClass="login-subtitle"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <ComboBox fx:id="cbSort" promptText="Default Sorting" styleClass="custom-combo-box" style="-fx-background-color: rgba(255,255,255,0.05); -fx-border-color: rgba(255,255,255,0.1);"/>
        </HBox>

        <ScrollPane fx:id="scrollPane" fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
            <content>
                <FlowPane fx:id="booksContainer" hgap="25.0" vgap="30.0" alignment="TOP_LEFT">
                    <padding>
                        <Insets top="10.0" right="10.0" bottom="20.0" left="0.0"/>
                    </padding>
                </FlowPane>
            </content>
        </ScrollPane>

        <HBox alignment="CENTER" spacing="10.0">
            <padding><Insets top="15.0"/></padding>
            <Button text="&lt; Prev" styleClass="btn-page"/>
            <Button text="1" styleClass="btn-page, btn-page-active"/>
            <Button text="2" styleClass="btn-page"/>
            <Button text="3" styleClass="btn-page"/>
            <Label text="..." style="-fx-text-fill: white; -fx-padding: 0 5;"/>
            <Button text="Next &gt;" styleClass="btn-page"/>
        </HBox>
    </VBox>

    <fx:include fx:id="bookDetailSidePanel" source="components/BookDetailSidePanelView.fxml" />

</HBox>