<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="1600.0" prefWidth="1000.0" spacing="20.0" styleClass="bg-white" stylesheets="@../css/theme.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bookstore.frontend.controller.ShopController">

    <children>
        <VBox alignment="CENTER" spacing="8.0" style="-fx-padding: 5 0 0 0;">
            <children>
                <Label style="-fx-text-fill: -fx-accent-gold;" text="Explore All Books Here">
                    <font>
                        <Font name="System Bold" size="32.0" />
                    </font>
                </Label>

                <Label style="-fx-text-fill: #666666;" text="Browse your favorite books, discover classics, and explore more beyond the featured collection." textAlignment="CENTER" wrapText="true">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Label>
            </children>
        </VBox>

        <HBox alignment="CENTER" spacing="10.0" style="-fx-padding: 5 0 5 0;">
            <children>
                <TextField prefWidth="420.0" promptText="Search by title, author, or keyword..." style="-fx-background-radius: 20; -fx-padding: 10 16 10 16;" />
                <Button mnemonicParsing="false" styleClass="btn-primary" text="Search" />
            </children>
        </HBox>

        <HBox alignment="CENTER" spacing="20.0" style="-fx-padding: 6 0 10 0;">
            <children>
                <CheckBox selected="true" style="-fx-font-size: 13;" text="All" />
                <CheckBox style="-fx-font-size: 13;" text="Fantasy" />
                <CheckBox style="-fx-font-size: 13;" text="Classic" />
                <CheckBox style="-fx-font-size: 13;" text="Mystery" />
                <CheckBox style="-fx-font-size: 13;" text="Self-help" />
                <CheckBox style="-fx-font-size: 13;" text="Other" />
            </children>
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #faf7ef; -fx-background-radius: 10; -fx-padding: 12 18 12 18;">
            <children>
                <Label style="-fx-text-fill: #666666;" text="12 books available">
                    <font>
                        <Font size="13.0" />
                    </font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                <Label style="-fx-text-fill: -fx-primary-black;" text="Sort by:">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Label>
                <Button mnemonicParsing="false" style="-fx-background-color: white; -fx-border-color: #d8c27a; -fx-border-radius: 16; -fx-background-radius: 16;" text="Popular" />
                <Button mnemonicParsing="false" style="-fx-background-color: white; -fx-border-color: #d8c27a; -fx-border-radius: 16; -fx-background-radius: 16;" text="Newest" />
                <Button mnemonicParsing="false" style="-fx-background-color: white; -fx-border-color: #d8c27a; -fx-border-radius: 16; -fx-background-radius: 16;" text="Price" />
            </children>
        </HBox>

        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: white;" VBox.vgrow="ALWAYS">
            <content>
                <FlowPane fx:id="bookContainer" alignment="TOP_CENTER" hgap="25.0" prefHeight="1300.0" prefWrapLength="900.0" style="-fx-padding: 20 10 20 10;" vgap="25.0" />
            </content>
        </ScrollPane>

    </children>

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>