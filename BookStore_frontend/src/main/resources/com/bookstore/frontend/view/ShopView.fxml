<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox prefHeight="800.0" prefWidth="1200.0" spacing="30.0"
      style="-fx-background-color: transparent;"
      stylesheets="@../css/colors.css,@../css/theme.css"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.bookstore.frontend.controller.ShopController">

    <padding>
        <Insets top="30.0" right="40.0" bottom="30.0" left="40.0"/>
    </padding>

    <VBox minWidth="260.0" prefWidth="260.0" spacing="25.0" styleClass="sidebar-panel">
        <padding>
            <Insets top="25.0" right="20.0" bottom="25.0" left="20.0"/>
        </padding>

        <VBox spacing="10.0">
            <Label text="Search" styleClass="login-title" style="-fx-font-size: 16px; -fx-text-fill: -fx-accent-gold;"/>

            <HBox alignment="CENTER_LEFT" styleClass="search-container-modern" style="-fx-background-color: rgba(255,255,255,0.05); -fx-background-radius: 4px; -fx-padding: 2px;">
                <TextField fx:id="txtSearch" promptText="Search your book..." styleClass="search-input-modern" style="-fx-background-color: transparent; -fx-text-fill: white;" HBox.hgrow="ALWAYS" />
            </HBox>
        </VBox>

        <VBox spacing="15.0">
            <Label text="Price Range" styleClass="login-title" style="-fx-font-size: 16px; -fx-text-fill: -fx-accent-gold;"/>
            <HBox spacing="10.0" alignment="CENTER_LEFT">
                <TextField fx:id="txtMinPrice" promptText="Min đ" styleClass="custom-text-field" prefWidth="80.0" style="-fx-background-color: rgba(255,255,255,0.05); -fx-text-fill: white;"/>
                <Label text="-" style="-fx-text-fill: white;"/>
                <TextField fx:id="txtMaxPrice" promptText="Max đ" styleClass="custom-text-field" prefWidth="80.0" style="-fx-background-color: rgba(255,255,255,0.05); -fx-text-fill: white;"/>
            </HBox>
        </VBox>

        <VBox spacing="15.0">
            <Label text="Categories" styleClass="login-title" style="-fx-font-size: 16px; -fx-text-fill: -fx-accent-gold;"/>

            <TextField fx:id="txtCategorySearch" promptText="Tìm thể loại..." styleClass="custom-text-field" style="-fx-background-color: rgba(255,255,255,0.05); -fx-text-fill: white; -fx-padding: 5 10; -fx-background-radius: 4px;"/>

            <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;" prefHeight="250.0">
                <content>
                    <VBox fx:id="categoriesContainer" spacing="10.0">
                    </VBox>
                </content>
            </ScrollPane>
        </VBox>
    </VBox>

    <VBox HBox.hgrow="ALWAYS" spacing="20.0">
        <HBox alignment="BOTTOM_LEFT">
            <VBox spacing="5.0">
                <Label text="All Books" styleClass="login-title" style="-fx-font-size: 32px;"/>
                <Label fx:id="lblStatus" text="Showing results..." styleClass="login-subtitle"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <ComboBox fx:id="cbSort" promptText="Default Sorting" styleClass="custom-combo-box" style="-fx-background-color: rgba(255,255,255,0.05); -fx-border-color: rgba(255,255,255,0.1);"/>
        </HBox>

        <ScrollPane fx:id="scrollPane" fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
            <content>
                <FlowPane fx:id="booksContainer" hgap="25.0" vgap="30.0" alignment="TOP_LEFT">
                    <padding>
                        <Insets top="10.0" right="10.0" bottom="20.0" left="0.0"/>
                    </padding>
                </FlowPane>
            </content>
        </ScrollPane>

        <HBox alignment="CENTER" spacing="10.0">
            <padding><Insets top="15.0"/></padding>
            <Button text="&lt; Prev" styleClass="btn-page"/>
            <Button text="1" styleClass="btn-page, btn-page-active"/>
            <Button text="2" styleClass="btn-page"/>
            <Button text="3" styleClass="btn-page"/>
            <Label text="..." style="-fx-text-fill: white; -fx-padding: 0 5;"/>
            <Button text="Next &gt;" styleClass="btn-page"/>
        </HBox>
    </VBox>

    <fx:include fx:id="bookDetailSidePanel" source="components/BookDetailSidePanelView.fxml" />

</HBox>