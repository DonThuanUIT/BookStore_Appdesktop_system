<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<StackPane fx:id="rootStackPane" prefHeight="700.0" prefWidth="1100.0"
           stylesheets="@../css/colors.css, @../css/theme.css"
           xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.bookstore.frontend.controller.LoginController">
   <children>
      <ImageView fx:id="backgroundImage" pickOnBounds="true" preserveRatio="false">
         <image>
            <Image url="@../image/libraryBackground.jpg" />
         </image>
      </ImageView>

      <Pane styleClass="overlay" />

      <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity"
            prefHeight="550.0" prefWidth="450.0" spacing="10.0" styleClass="login-box">

         <children>
            <VBox fx:id="loginForm" alignment="CENTER" spacing="24.0">
               <children>

                  <VBox alignment="CENTER" spacing="5.0">
                     <Label styleClass="login-title" text="Chào mừng trở lại" style="-fx-font-size: 32px;" />
                     <Label styleClass="login-subtitle" text="Đăng nhập để khám phá kho sách của chúng tôi." />
                  </VBox>

                  <TextField fx:id="txtUsername" promptText="Tên đăng nhập hoặc Email" styleClass="custom-text-field" />

                  <StackPane>
                     <PasswordField fx:id="txtPassword" promptText="Mật khẩu" styleClass="custom-text-field" />
                     <TextField fx:id="txtPasswordVisible" managed="false" visible="false"
                                promptText="Mật khẩu" styleClass="custom-text-field" />
                     <Button fx:id="btnTogglePassword" onAction="#togglePassword" text="📕"
                             StackPane.alignment="CENTER_RIGHT" styleClass="btn-icon" />
                  </StackPane>

                  <HBox alignment="CENTER_LEFT">
                     <children>
                        <CheckBox mnemonicParsing="false" styleClass="custom-checkbox" text="Ghi nhớ đăng nhập" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Hyperlink onAction="#handleNavigateToForgotPassword" styleClass="text-link" text="Quên mật khẩu?" />
                     </children>
                  </HBox>

                  <StackPane>
                     <children>
                        <Button fx:id="btnLogin" onAction="#handleLogin" maxWidth="Infinity"
                                mnemonicParsing="false" styleClass="login-button" text="Đăng nhập" />

                        <VBox fx:id="loadingContainer" alignment="CENTER" spacing="5.0" visible="false" managed="false">
                           <children>
                              <ProgressIndicator prefHeight="40.0" prefWidth="40.0" />
                              <Label text="Đang xác thực..." style="-fx-text-fill: -fx-accent-gold; -fx-font-size: 12px;" />
                           </children>
                        </VBox>
                     </children>
                     <VBox.margin><Insets top="10.0" /></VBox.margin>
                  </StackPane>

                  <HBox alignment="CENTER" spacing="5.0">
                     <children>
                        <Label styleClass="login-subtitle" text="Bạn chưa có tài khoản?" />
                        <Hyperlink onAction="#handleNavigateToRegister" styleClass="text-link" text="Đăng ký ngay" />
                     </children>
                  </HBox>
               </children>
            </VBox>

            <Label fx:id="lblMessage" textAlignment="CENTER" styleClass="text-error" wrapText="true" />
         </children>

         <padding>
            <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
         </padding>
      </VBox>
   </children>
</StackPane>