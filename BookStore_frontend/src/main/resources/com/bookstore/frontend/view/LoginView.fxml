<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<StackPane fx:id="rootStackPane" prefHeight="650.0" prefWidth="1000.0"
           stylesheets="@../css/theme.css"
           xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.bookstore.frontend.controller.LoginController">
   <children>
      <ImageView fx:id="backgroundImage" pickOnBounds="true" preserveRatio="false">
         <image>
            <Image url="@../image/libraryBackground.jpg" />
         </image>
      </ImageView>

      <Pane styleClass="overlay" />

      <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity"
            prefHeight="520.0" prefWidth="420.0" spacing="10.0" styleClass="login-box">
         <children>
            <VBox fx:id="loginForm" alignment="CENTER" spacing="18.0">
               <children>
                  <Label styleClass="login-title" text="LOGIN" />
                  <Label styleClass="login-subtitle" text="Book Store Management System">
                     <VBox.margin><Insets top="-15.0" bottom="10.0" /></VBox.margin>
                  </Label>

                  <TextField fx:id="txtUsername" promptText="Username" styleClass="custom-text-field" />

                  <StackPane>
                     <PasswordField fx:id="txtPassword" promptText="Password" styleClass="custom-text-field" />
                     <TextField fx:id="txtPasswordVisible" managed="false" visible="false" styleClass="custom-text-field" />
                     <Button fx:id="btnTogglePassword" onAction="#togglePassword" text="👁"
                             StackPane.alignment="CENTER_RIGHT"
                             style="-fx-background-color: transparent; -fx-text-fill: #00bcd4; -fx-cursor: hand;" />
                  </StackPane>

                  <HBox alignment="CENTER_LEFT">
                     <children>
                        <CheckBox mnemonicParsing="false" styleClass="custom-checkbox" text="Remember me" textFill="WHITE" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Hyperlink onAction="#handleNavigateToRegister" styleClass="forgot-link" text="Forgot password?" />
                     </children>
                  </HBox>

                  <StackPane>
                     <children>
                        <Button fx:id="btnLogin" onAction="#handleLogin" maxWidth="Infinity"
                                mnemonicParsing="false" styleClass="login-button" text="Log in" />

                        <VBox fx:id="loadingContainer" alignment="CENTER" spacing="5.0" visible="false" managed="false">
                           <children>
                              <ProgressIndicator prefHeight="40.0" prefWidth="40.0" />
                              <Label text="Authenticating..." textFill="#d8c27a" style="-fx-font-size: 12px;" />
                           </children>
                        </VBox>
                     </children>
                     <VBox.margin><Insets top="10.0" /></VBox.margin>
                  </StackPane>

                  <HBox alignment="CENTER" spacing="5.0">
                     <children>
                        <Label styleClass="register-label" text="Don't have an account?" />
                        <Hyperlink onAction="#handleNavigateToRegister" styleClass="register-link" text="Register now" />
                     </children>
                  </HBox>
               </children>
            </VBox>

            <Label fx:id="lblMessage" textAlignment="CENTER" textFill="#ff6b6b" wrapText="true" />
         </children>
         <padding>
            <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
         </padding>
      </VBox>
   </children>
</StackPane>