<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<StackPane fx:id="rootStackPane" prefHeight="700.0" prefWidth="1100.0"
           stylesheets="@../css/colors.css, @../css/theme.css"
           xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.bookstore.frontend.controller.ForgotPasswordController">
    <children>
        <!-- 1. Background Image (Tủ sách) -->
        <ImageView fx:id="backgroundImage" pickOnBounds="true" preserveRatio="false">
            <image>
                <Image url="@../image/libraryBackground.jpg" />
            </image>
        </ImageView>

        <!-- 2. Lớp phủ Overlay -->
        <Pane styleClass="overlay" />

        <!-- 3. Form Glassmorphism -->
        <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity"
              prefHeight="480.0" prefWidth="420.0" spacing="10.0" styleClass="login-box">

            <children>
                <VBox fx:id="forgotPasswordForm" alignment="CENTER" spacing="24.0">
                    <children>

                        <!-- Icon Cuốn sách (Dùng Unicode Text để không cần load thư viện ngoài) -->
                        <Label text="📖" style="-fx-text-fill: -fx-accent-gold; -fx-font-size: 42px;" />

                        <!-- Header -->
                        <VBox alignment="CENTER" spacing="8.0">
                            <Label styleClass="login-title" text="Reset Password" style="-fx-font-size: 36px;"/>
                            <Label styleClass="login-subtitle" text="Enter your email to receive recovery instructions." textAlignment="CENTER" wrapText="true" />
                        </VBox>

                        <!-- Ô nhập Email -->
                        <TextField fx:id="txtEmail" promptText="Email Address" styleClass="custom-text-field" />

                        <!-- Nút Gửi & Loading -->
                        <StackPane>
                            <children>
                                <Button fx:id="btnSendResetLink" onAction="#handleSendResetLink" maxWidth="Infinity"
                                        mnemonicParsing="false" styleClass="login-button" text="Send Reset Link" />

                                <VBox fx:id="loadingContainer" alignment="CENTER" spacing="5.0" visible="false" managed="false">
                                    <children>
                                        <ProgressIndicator prefHeight="40.0" prefWidth="40.0" />
                                        <Label text="Sending link..." style="-fx-text-fill: -fx-accent-gold; -fx-font-size: 12px;" />
                                    </children>
                                </VBox>
                            </children>
                            <VBox.margin><Insets top="10.0" /></VBox.margin>
                        </StackPane>

                        <!-- Footer (Quay lại Login) -->
                        <HBox alignment="CENTER" spacing="5.0">
                            <children>
                                <Label styleClass="login-subtitle" text="Remembered your password?" />
                                <Hyperlink onAction="#goToLogin" styleClass="text-link" text="Back to Login" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <!-- Nhãn hiển thị thông báo (Thành công/Thất bại) -->
                <Label fx:id="lblMessage" textAlignment="CENTER" styleClass="text-error" wrapText="true">
                    <VBox.margin><Insets top="20.0" /></VBox.margin>
                </Label>
            </children>

            <!-- Khoảng đệm -->
            <padding>
                <Insets bottom="40.0" left="30.0" right="30.0" top="30.0" />
            </padding>
        </VBox>
    </children>
</StackPane>