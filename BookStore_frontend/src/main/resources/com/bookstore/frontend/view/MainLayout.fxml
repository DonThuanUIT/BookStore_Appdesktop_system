<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="800.0" prefWidth="1200.0"
            style="-fx-background-color: -fx-primary-black;"
            stylesheets="@../css/colors.css, @../css/theme.css"
            xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.bookstore.frontend.controller.MainController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="75.0" spacing="0.0" styleClass="nav-bar" BorderPane.alignment="CENTER">
            <children>
                <!-- Logo bên trái -->
                <Label styleClass="login-title" text="Neth Bookpoint" style="-fx-font-size: 24px;">
                    <padding>
                        <Insets left="10.0" />
                    </padding>
                </Label>

                <Region HBox.hgrow="ALWAYS" />

                <!-- Menu chính ở giữa -->
                <HBox alignment="CENTER" spacing="15.0">
                    <children>
                        <Button fx:id="btnHome" onAction="#onHomeClick" styleClass="nav-button" text="Home" />
                        <Button fx:id="btnShop" onAction="#onShopNavClick" styleClass="nav-button" text="Shop" />
                        <Button fx:id="btnCart" onAction="#onCartClick" styleClass="nav-button" text="Cart" />
                        <Button fx:id="btnInventory" onAction="#onInventoryClick" styleClass="nav-button" text="Inventory" />
                    </children>
                </HBox>

                <Region HBox.hgrow="ALWAYS" />

                <!-- Khu vực Profile/Cart Icon bên phải -->
                <HBox alignment="CENTER_RIGHT" spacing="20.0">
                    <children>
                        <Button mnemonicParsing="false" styleClass="btn-icon" text="👤" style="-fx-font-size: 18px;" />
                        <StackPane>
                            <children>
                                <Button mnemonicParsing="false" styleClass="btn-icon" text="🛍" style="-fx-font-size: 18px;" />
                                <!-- Badge số lượng (Tạm thời) -->
                                <Label text="2" style="-fx-background-color: -fx-error-red; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 1 5; -fx-font-size: 10px;"
                                       StackPane.alignment="TOP_RIGHT">
                                    <StackPane.margin>
                                        <Insets right="-5.0" top="-5.0" />
                                    </StackPane.margin>
                                </Label>
                            </children>
                        </StackPane>
                    </children>
                </HBox>
            </children>
            <padding>
                <Insets left="30.0" right="30.0" />
            </padding>
        </HBox>
    </top>

    <center>
        <!-- ScrollPane trong suốt để không bị lộ nền trắng -->
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" BorderPane.alignment="CENTER">
            <content>
                <StackPane fx:id="contentArea" alignment="TOP_CENTER" style="-fx-background-color: -fx-primary-black;">
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                </StackPane>
            </content>
        </ScrollPane>
    </center>

</BorderPane>