<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="800.0" prefWidth="1200.0" styleClass="bg-black" stylesheets="@../css/theme.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bookstore.frontend.controller.MainController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="70.0" spacing="20.0" styleClass="nav-bar" BorderPane.alignment="CENTER">
            <children>

                <Label style="-fx-text-fill: -fx-accent-gold;" text="Neth Bookpoint">
                    <font>
                        <Font name="System Bold" size="22.0" />
                    </font>
                </Label>

                <Region HBox.hgrow="ALWAYS" />

                <HBox alignment="CENTER" spacing="10.0">
                    <children>
                        <Button fx:id="btnHome" mnemonicParsing="false" onAction="#onHomeClick" styleClass="nav-button" text="Home" />
                        <Button fx:id="btnShop" mnemonicParsing="false" onAction="#onShopNavClick" styleClass="nav-button" text="Shop" />
                        <Button fx:id="btnCart" mnemonicParsing="false" onAction="#onCartClick" styleClass="nav-button" text="Cart" />
                        <Button fx:id="btnInventory" mnemonicParsing="false" onAction="#onInventoryClick" styleClass="nav-button" text="Inventory" />
                    </children>
                </HBox>

                <Region HBox.hgrow="ALWAYS" />

                <HBox alignment="CENTER_RIGHT" spacing="12.0">
                    <children>
                        <Button mnemonicParsing="false" styleClass="nav-button" text="Profile" />
                    </children>
                </HBox>

            </children>
            <padding>
                <Insets left="20.0" right="20.0" />
            </padding>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: white; -fx-border-color: transparent;" BorderPane.alignment="CENTER">
            <content>
                <StackPane fx:id="contentArea" alignment="TOP_CENTER" styleClass="bg-white" />
            </content>
        </ScrollPane>
    </center>

</BorderPane>
