<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane prefHeight="800.0" prefWidth="1200.0"
           styleClass="main-background"
           stylesheets="@../css/colors.css, @../css/theme.css"
           xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.bookstore.frontend.controller.MainController">


    <Pane styleClass="overlay" />

    <BorderPane style="-fx-background-color: transparent;">

        <top>
            <HBox alignment="CENTER_LEFT" prefHeight="75.0" spacing="0.0" styleClass="nav-bar" BorderPane.alignment="CENTER">
                <children>
                    <Label styleClass="login-title" text="Neth Bookpoint" style="-fx-font-size: 24px;">
                        <padding><Insets left="10.0" /></padding>
                    </Label>
                    <Region HBox.hgrow="ALWAYS" />
                    <HBox alignment="CENTER" spacing="15.0">
                        <children>
                            <Button fx:id="btnHome" onAction="#onHomeClick" styleClass="nav-button" text="Home" />
                            <Button fx:id="btnShop" onAction="#onShopNavClick" styleClass="nav-button" text="Shop" />
                            <Button fx:id="btnCart" onAction="#onCartClick" styleClass="nav-button" text="Cart" />
                            <Button fx:id="btnInventory" onAction="#onInventoryClick" styleClass="nav-button" text="Inventory" />

                            <Button fx:id="btnImport" onAction="#onImportClick" styleClass="nav-button" text="Import" />
                            <Button fx:id="btnRevenue" onAction="#onRevenueClick" styleClass="nav-button" text="Revenue"/>
                        </children>
                    </HBox>
                    <Region HBox.hgrow="ALWAYS" />
                    <HBox alignment="CENTER_RIGHT" spacing="20.0">
                        <children>
                            <!-- Trong file FXML của bạn -->
                            <Button fx:id="btnAccount" mnemonicParsing="false" onAction="#onAccountClick" styleClass="btn-icon" text="👤" />                            <StackPane>
                                <children>
                                    <Button fx:id="btnNavMiniCart" mnemonicParsing="false" onAction="#onNavMiniCartClick"
                                            styleClass="btn-icon" text="🛒"
                                            style="-fx-font-size: 20px; -fx-padding: 10 12; -fx-min-width: 48; -fx-min-height: 48; -fx-max-width: 48; -fx-max-height: 48; -fx-background-radius: 14; -fx-background-color: rgba(0,0,0,0.45); -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.35), 12, 0.2, 0, 2);" />
                                    <Label fx:id="lblCartBadge" text=""
                                           style="-fx-background-color: -fx-error-red; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 2 6; -fx-font-size: 10px; -fx-font-weight: bold;"
                                           StackPane.alignment="TOP_RIGHT" visible="false" managed="false">
                                        <StackPane.margin><Insets right="-4.0" top="-4.0" /></StackPane.margin>
                                    </Label>
                                </children>
                            </StackPane>
                        </children>
                    </HBox>
                </children>
                <padding><Insets left="30.0" right="30.0" /></padding>
            </HBox>
        </top>

        <center>
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" BorderPane.alignment="CENTER">
                <content>
                    <StackPane fx:id="contentArea" alignment="TOP_CENTER" style="-fx-background-color: transparent;">
                        <padding>
                            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                        </padding>
                    </StackPane>
                </content>
            </ScrollPane>
        </center>

    </BorderPane>
</StackPane>