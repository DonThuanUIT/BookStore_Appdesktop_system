<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.bookstore.frontend.controller.OrderHistoryController"
      spacing="15.0" style="-fx-background-color: #1A1A1A; -fx-padding: 20;"
      stylesheets="@../css/colors.css,@../css/theme.css">
    
    <!-- Header -->
    <VBox spacing="5.0">
        <Label fx:id="lblTitle" text="Lịch sử Đơn Hàng" style="-fx-font-size: 24px; -fx-text-fill: #FFC107; -fx-font-weight: bold;" />
        <Label text="Quản lý và tra cứu các đơn hàng" style="-fx-text-fill: #AAAAAA; -fx-font-size: 13px;" />
    </VBox>

    <!-- Table View -->
    <TableView fx:id="orderTable" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-base: #1A1A1A; -fx-control-inner-background: #252525; -fx-table-cell-border-color: #333333; -fx-text-fill: white;">
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
        <columns>
            <TableColumn fx:id="colId" text="Mã Đơn" prefWidth="80" />
            <TableColumn fx:id="colDate" text="Ngày đặt" prefWidth="120" />
            <TableColumn fx:id="colTotal" text="Tổng tiền" prefWidth="100" />
            <TableColumn fx:id="colStatus" text="Trạng thái" prefWidth="100" />
            <TableColumn fx:id="colPayment" text="Thanh toán" prefWidth="100" />
            <TableColumn fx:id="colAction" text="Hành động" prefWidth="100" />
        </columns>
    </TableView>

    <!-- Pagination Controls -->
    <BorderPane style="-fx-background-color: #252525; -fx-padding: 15; -fx-background-radius: 8; -fx-border-color: #333333; -fx-border-width: 1;">
        <left>
            <Label fx:id="lblPaginationInfo" text="Đang tải..." textFill="#AAAAAA" 
                   style="-fx-font-size: 13px;" BorderPane.alignment="CENTER_LEFT" />
        </left>
        <right>
            <HBox spacing="10.0" alignment="CENTER_RIGHT" BorderPane.alignment="CENTER">
                <Button fx:id="btnPrevPage" onAction="#handlePrevPage" text="◀ Trước" 
                        style="-fx-background-color: #FFC107; -fx-text-fill: #1A1A1A; -fx-padding: 8 15; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" />
                <Button fx:id="btnNextPage" onAction="#handleNextPage" text="Tiếp ▶" 
                        style="-fx-background-color: #FFC107; -fx-text-fill: #1A1A1A; -fx-padding: 8 15; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" />
            </HBox>
        </right>
    </BorderPane>
    
    <!-- Container for pagination controls VBox -->
    <fx:define>
        <VBox fx:id="paginationControls" />
    </fx:define>
    
</VBox>