<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.bookstore.frontend.controller.OrderHistoryController">
    <children>
        <Label text="Lịch sử đơn hàng" style="-fx-font-size: 18px; -fx-padding: 10;" />

        <TableView fx:id="orderTable" VBox.vgrow="ALWAYS">
            <!-- Thay đổi cách khai báo ở đây -->
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>

            <columns>
                <TableColumn fx:id="colId" text="Mã Đơn" prefWidth="80" />
                <TableColumn fx:id="colDate" text="Ngày đặt" prefWidth="120" />
                <TableColumn fx:id="colTotal" text="Tổng tiền" prefWidth="100" />
                <TableColumn fx:id="colStatus" text="Trạng thái" prefWidth="100" />
                <TableColumn fx:id="colPayment" text="Thanh toán" prefWidth="100" />
                <TableColumn fx:id="colDiscount" text="Giảm giá" prefWidth="100" />
            </columns>
        </TableView>
    </children>
</VBox>