<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bookstore.frontend.controller.OrderHistoryController" stylesheets="@../../css/colors.css,@../../css/theme.css">

    <VBox spacing="20.0" style="-fx-background-color: #1A1A1A; -fx-padding: 30;">
        <BorderPane>
            <left>
                <VBox spacing="5.0">
                    <Label fx:id="lblTitle" text="Lịch sử đơn hàng" textFill="#FFC107">
                        <font>
                            <Font name="System Bold" size="28.0" />
                        </font>
                    </Label>
                    <Label text="Quản lý và tra cứu thông tin đơn hàng đã mua" textFill="#AAAAAA">
                        <font>
                            <Font size="14.0" />
                        </font>
                    </Label>
                </VBox>
            </left>
        </BorderPane>



        <!-- Table View -->
        <TableView fx:id="orderTable" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-base: #1A1A1A; -fx-control-inner-background: #252525; -fx-table-cell-border-color: #333333; -fx-text-fill: white;">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="colId" text="MÃ ĐƠN" prefWidth="90" styleClass="align-center" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colDate" text="NGÀY ĐẶT" prefWidth="150" styleClass="align-center" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colTotal" text="TỔNG TIỀN" prefWidth="120" styleClass="align-right" style="-fx-alignment: CENTER-RIGHT;" />
                <TableColumn fx:id="colDiscount" text="GIẢM GIÁ" prefWidth="100" styleClass="align-right" style="-fx-alignment: CENTER-RIGHT;" />
                <TableColumn fx:id="colPayment" text="P.T. THANH TOÁN" prefWidth="140" styleClass="align-center" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colStatus" text="TRẠNG THÁI" prefWidth="120" styleClass="align-center" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colDetail" text="CHI TIẾT" prefWidth="100" styleClass="align-center" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colAction" text="HÀNH ĐỘNG" prefWidth="150" styleClass="align-center" style="-fx-alignment: CENTER;" />
            </columns>
        </TableView>

        <!-- Pagination Controls -->
        <BorderPane>
            <left>
                <Label fx:id="lblPaginationInfo" text="Showing 0 entries" textFill="#AAAAAA" BorderPane.alignment="CENTER" />
            </left>
            <right>
                <HBox spacing="10.0" alignment="CENTER_RIGHT" BorderPane.alignment="CENTER">
                    <Button fx:id="btnPrevPage" onAction="#handlePrevPage" text="&#60; Trước" styleClass="btn-page" style="-fx-background-color: #252525; -fx-text-fill: white; -fx-cursor: hand;" />
                    <Label fx:id="lblCurrentPage" text="1" style="-fx-background-color: #FFC107; -fx-text-fill: #1A1A1A; -fx-padding: 5 12; -fx-background-radius: 3; -fx-font-weight: bold; -fx-min-width: 32; -fx-alignment: center;" />
                    <Button fx:id="btnNextPage" onAction="#handleNextPage" text="Sau >" styleClass="btn-page" style="-fx-background-color: #252525; -fx-text-fill: white; -fx-cursor: hand;" />
                </HBox>
            </right>
        </BorderPane>
    </VBox>

    <!-- Side panel chi tiết đơn hàng -->
    <fx:include fx:id="orderDetailSidePanel" source="OrderDetailSidePanelView.fxml" StackPane.alignment="CENTER_RIGHT" />

</StackPane>