<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bookstore.frontend.controller.OrderHistoryController" stylesheets="@../../css/colors.css,@../../css/theme.css">

    <VBox spacing="20.0" style="-fx-background-color: #1A1A1A; -fx-padding: 30;">
        <BorderPane>
            <left>
                <VBox spacing="5.0">
                    <Label fx:id="lblTitle" text="Lịch sử đơn hàng" textFill="#FFC107">
                        <font>
                            <Font name="System Bold" size="28.0" />
                        </font>
                    </Label>
                    <Label text="Quản lý và tra cứu thông tin đơn hàng đã mua" textFill="#AAAAAA">
                        <font>
                            <Font size="14.0" />
                        </font>
                    </Label>
                </VBox>
            </left>
        </BorderPane>

        <!-- Filter Controls -->
        <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #252525; -fx-padding: 15; -fx-background-radius: 10;">
            <TextField fx:id="txtSearch" prefWidth="280.0" promptText="🔍 Tìm theo mã đơn, khách hàng..." style="-fx-background-color: #1A1A1A; -fx-text-fill: white; -fx-prompt-text-fill: #777777; -fx-border-color: #333333; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8;" />
            
            <ComboBox fx:id="cbStatus" prefWidth="150.0" promptText="Trạng thái" style="-fx-background-color: #1A1A1A; -fx-border-color: #333333; -fx-border-radius: 5; -fx-text-fill: white;" />
            
            <Region HBox.hgrow="ALWAYS" />
            
            <DatePicker fx:id="dpFrom" promptText="Từ ngày" style="-fx-background-color: #1A1A1A; -fx-base: #1A1A1A; -fx-control-inner-background: #1A1A1A;" />
            <DatePicker fx:id="dpTo" promptText="Đến ngày" style="-fx-background-color: #1A1A1A; -fx-base: #1A1A1A; -fx-control-inner-background: #1A1A1A;" />
            <Button onAction="#handleFilter" style="-fx-background-color: transparent; -fx-border-color: #FFC107; -fx-text-fill: #FFC107; -fx-border-radius: 5; -fx-padding: 6 18; -fx-cursor: hand;" text="Lọc" />
        </HBox>

        <!-- Table View -->
        <TableView fx:id="orderTable" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-base: #1A1A1A; -fx-control-inner-background: #252525; -fx-table-cell-border-color: #333333; -fx-text-fill: white;">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="colId" text="MÃ ĐƠN" prefWidth="90" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colDate" text="NGÀY ĐẶT" prefWidth="150" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colTotal" text="TỔNG TIỀN" prefWidth="120" style="-fx-alignment: CENTER_RIGHT;" />
                <TableColumn fx:id="colDiscount" text="GIẢM GIÁ" prefWidth="100" style="-fx-alignment: CENTER_RIGHT;" />
                <TableColumn fx:id="colPayment" text="P.T. THANH TOÁN" prefWidth="140" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colStatus" text="TRẠNG THÁI" prefWidth="120" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colAction" text="HÀNH ĐỘNG" prefWidth="150" style="-fx-alignment: CENTER;" />
            </columns>
        </TableView>

        <!-- Pagination Controls -->
        <BorderPane>
            <left>
                <Label fx:id="lblPaginationInfo" text="Showing 0 entries" textFill="#AAAAAA" BorderPane.alignment="CENTER" />
            </left>
            <right>
                <HBox spacing="10.0" alignment="CENTER_RIGHT" BorderPane.alignment="CENTER">
                    <Button fx:id="btnPrevPage" onAction="#handlePrevPage" text="< Trước" styleClass="btn-page" style="-fx-background-color: #252525; -fx-text-fill: white; -fx-cursor: hand;" />
                    <Label fx:id="lblCurrentPage" text="1" style="-fx-background-color: #FFC107; -fx-text-fill: #1A1A1A; -fx-padding: 5 12; -fx-background-radius: 3; -fx-font-weight: bold; -fx-min-width: 32; -fx-alignment: center;" />
                    <Button fx:id="btnNextPage" onAction="#handleNextPage" text="Sau >" styleClass="btn-page" style="-fx-background-color: #252525; -fx-text-fill: white; -fx-cursor: hand;" />
                </HBox>
            </right>
        </BorderPane>
    </VBox>

    <!-- Side panel chi tiết đơn hàng -->
    <fx:include fx:id="orderDetailSidePanel" source="OrderDetailSidePanelView.fxml" StackPane.alignment="CENTER_RIGHT" />

</StackPane>